{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/session-start.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'echo \"${CLAUDE_TOOL_INPUT:-}\" | grep -q gdrive-sa.json && bash .claude/hooks/session-start.sh || true'"
          }
        ]
      }
    ]
  }
}
